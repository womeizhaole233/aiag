      }
    ]
  },
  "n00039": {
    "next": "n00041",
    "bg": "static/images/楔子/ChatGPT Image Jun 22, 2026, 07_32_40 PM.png",
    "portrait": "static/images/portraits/粟柏年2.png"
  },
  "n00018": {
    "text": "她歪着头，想了一下，略带疑惑地说：",
    "bg": "static/images/楔子/ChatGPT Image Jun 22, 2026, 01_49_19 AM.png",
    "portrait": "static/images/portraits/周淼2.png"
  },
  "n00055": {
    "text": "棚子最里面亮着一盏小灯，一个戴圆框眼镜的年轻人正伏在矮桌边。圆脸，皮肤很白，手指细长。桌上摊着几块用纱布包好的骨骼标本。他正用游标卡尺量一块髋骨碎片。",
    "bg": "static/images/楔子/ChatGPT Image Jun 22, 2026, 07_04_45 PM.png"
  },
  "n00060": {
    "text": "天还没亮透，风从华北平原的枯槁田野上刮过来，像一把钝锯子在骨头缝里来回拉。你跟着粟柏年爬上缓坡，工地在晨色里显出轮廓：几片探方，几盏马灯，帆布棚子被风吹得哗哗响。"
  },
  "n00061": {
    "text": "粟柏年停在高地边缘，从口袋里掏出一张折叠整齐的坐标纸，在晨雾里抖开。纸上是白沙宋墓群的平面草图，M1在最南端，靠近水库取土区的边缘。"
  },
  "n00063": {
    "text": "他把草图摊在一块平整的夯土断面上，用两块碎砖压住边角。图纸右上角印着一行小字：“白沙附近图”，标出了白沙镇、禹县、颖水的相对位置，水库工程取土区用斜线阴影标出，M1就在那片阴影的边缘。"
  },
  "n00064": {
    "text": "白沙镇在这个位置。墓群坐落在这道南北向土岗的东坡，海拔比周围农田高出约十五米。东南高，西北低。土岗北侧那条干涸的河道——西北到东南走向。"
  },
  "n00069": {
    "text": "待会儿你要进的是一座完整的墓，是一个从外到内的空间系统。每走一步，前面的发现都会重新被后面的证据检验。"
  },
  "n00073": {
    "text": "赵老倔扛着铁锹走上来，走到坡顶忽然停下脚步，用锹柄敲了敲脚下的地面，又侧耳听了听。他蹲下去，抓起一把土在掌心搓了搓。"
  },
  "n00080": {
    "text": "墓道口在土岗东坡的断层上切出一道规整的开口。粟柏年已经蹲在那儿了，手电光在晨雾里切出一道白柱，照在阶梯夯土的断面上。墓道北偏东十五度，现存长度将近六米，阶梯现存十一级，平坦部分将近两米。"
  },
  "n00082": {
    "text": "白光沿着夯土断面缓缓移动。一层，又一层，颜色几乎一样，却又有细微区别。"
  },
  "n00109": {
    "text": "如果是年号，后面应该能和题记、地券互证。现在还不能下结论。"
  },
  "n00125": {
    "text": "他把撬棍插进下一块砖缝里，忽然又停了一下。你透过刚取下的一块菱角牙子留下的砖孔往里看了一眼。"
  },
  "n00112": {
    "text": "封门砖从外层开始逐块拆除。陈怀远负责绘制封门砖的正视图，鼻梁上架着老花镜，一手按着坐标纸，运笔极稳。"
  },
  "n00113": {
    "text": "他忽然极低地哼了一句什么，调门起得很高，又陡然拐了个弯。赵老倔手里撬棍一顿，头也不抬。"
  },
  "n00139": {
    "text": "赵老倔扛着木料过来，扎稳马步，双手托着立柱往上一顶，腮帮子鼓起，脖子上青筋跳了一下。立柱架好之后，裂缝没有扩大。"
  },
  "n00187": {
    "text": "东壁是女乐图，卷帘下，女乐十一人分左右两组。右侧五人击鼓、击拍板、击腰鼓、吹横笛、吹觱篥。左侧五人吹箫、吹笙、吹排箫、弹琵琶。四排乐人之间，一人戴硬脚花额幞头，欠身扬袖作舞。"
  },
  "n00232": {
    "text": "头骨并列安放，枕骨朝下，面朝西偏北。身体其余部分的骨骼混堆在头骨东侧，小骨片散乱重叠，像被时间打翻的一盒棋子。"
  },
  "n00244": {
    "text": "头骨并列，其余骨骼混堆。你觉得最可能是什么情况？"
  },
  "n00255": {
    "text": "地券为砖质朱书，十六行、倒写，券盖无字，并有“合同”背书。第一行可辨认：“大宋元符二年九月十□日赵……”"
  },
  "n00311": {
    "text": "李公曰：府库之粮，皆在簿册——最后一个字残缺。水渍刚好浸掉了最关键的那个字。"
  },
  "n00316": {
    "text": "你继续往下读：若李公不知，便是小人自取，三千石算在小人头上。李公沉吟良久，终曰……此处又一处水渍，模糊了后半句。"
  },
  "n00323": {
    "text": "最后一处又有残损。你把绢帛拿到灯下，侧光极斜地照过去。几个字的结体从水渍里浮出来。第一个字，笔画中有“矢”部。"
  },
  "n00351": {
    "text": "一号墓全部测绘和记录工作于12月31日中午完成。陈怀远把最后一张测绘图从坐标纸上揭下来，对着光看了一遍，点了点头，卷好放进图筒。"
  },
  "n00356": {
    "text": "收工前，你最后一次走进后室。手电光照在北壁假门上。那个砖雕女子，垂双髻，右手作启门状。门微启，左扇永远停在推开的角度上。她在黑暗里站了九百多年。"
  },
  "n00001": {
    "bg": "static/images/楔子/ChatGPT Image Jun 22, 2026, 05_40_44 PM.png"
  },
  "n00003": {
    "bg": "static/images/楔子/ChatGPT Image Jun 22, 2026, 02_09_46 AM.png",
    "text": "后来外祖父再也没有提起过这里。只留下几张发黄的调查记录、一枚断开的银扣，以及一句谁也听不懂的话——“地下的东西，有时候比活人记性更好”。"
  },
