+def load_chapters():
+    """杩斿洖绔犺妭閰嶇疆鍒楄〃"""
+    if os.path.exists(CHAPTERS_FILE):
+        try:
+            with open(CHAPTERS_FILE, 'r', encoding='utf-8') as f:
+                data = json.load(f) or {}
+            return data.get('chapters', [])
